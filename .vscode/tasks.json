{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-B",
        "build",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_TOOLCHAIN_FILE=${VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "-DVCPKG_TARGET_TRIPLET=arm64-osx",
        "-DVCPKG_HOST_TRIPLET=arm64-osx",
        "-G",
        "Unix Makefiles"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$cmake"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "CMake: Configure (Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-B",
        "build_release",
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_TOOLCHAIN_FILE=${VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "-DVCPKG_TARGET_TRIPLET=arm64-osx",
        "-DVCPKG_HOST_TRIPLET=arm64-osx",
        "-G",
        "Unix Makefiles"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$cmake"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Build: Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--config",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["CMake: Configure (Debug)"]
    },
    {
      "label": "Build: Release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build_release",
        "--config",
        "Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "dependsOn": ["CMake: Configure (Release)"]
    },
    {
      "label": "Run: cfrp (Debug)",
      "type": "shell",
      "command": "./build/cfrp",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "dependsOn": ["Build: Debug"]
    }
  ]
}
